# ─── Admin access ────────────────────────────────────────────────────────────
# Comma-separated emails allowed to access /batch-audit and /admin/leads
# ADMIN_EMAILS=you@example.com,colleague@example.com
# NEXT_PUBLIC_ADMIN_EMAILS=you@example.com,colleague@example.com

# ─── Supabase service role (server-side only — never expose to browser) ───────
# Used by /api/capture and /api/admin/leads to write/read the leads table.
# Find in Supabase → Settings → API → service_role key
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Required for lead capture ───────────────────────────────────────────────
# Paste your Google Apps Script Web App URL here.
# In Google Sheets: Extensions → Apps Script → Deploy → New Deployment → Web App
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ─── Optional: PageSpeed API Key ─────────────────────────────────────────────
# Without a key, requests are rate-limited to ~25/day per IP.
# Get one free at: https://console.cloud.google.com → APIs → PageSpeed Insights API
# NEXT_PUBLIC_PAGESPEED_API_KEY=AIza...

# ─── Site URL (used for OG metadata, sitemap, and funnel deep links) ──────────
# Set this to your production domain so emails, OG cards, and sitemap use the right URL.
# NEXT_PUBLIC_SITE_URL=https://usenexus.io

# ─── LemonSqueezy checkout URLs ───────────────────────────────────────────────
# NEXT_PUBLIC_LS_PULSE_URL=https://your-store.lemonsqueezy.com/checkout/buy/PULSE_VARIANT_ID
# NEXT_PUBLIC_LS_SCALE_URL=https://your-store.lemonsqueezy.com/checkout/buy/SCALE_VARIANT_ID
# LS_WEBHOOK_SECRET=your_webhook_signing_secret
# LS_PULSE_VARIANT_ID=12345
# LS_SCALE_VARIANT_ID=67890

# ─── Batch audit / Admin password ────────────────────────────────────────────
# NEXT_PUBLIC_BATCH_PASSWORD=your_batch_password
